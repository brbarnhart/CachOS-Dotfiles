// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  // === Your custom Vim bindings ===
  {
    "context": "vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore",
    },
  },
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual)",
    "bindings": {
      "shift-h": ["workspace::SendKeystrokes", "^"], // start of line (first non-blank)
      "shift-l": ["workspace::SendKeystrokes", "$"], // end of line
    },
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "bindings": {
      "alt-j": "vim::GoToTab"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "g t": "vim::GoToTab"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "bindings": {
      "alt-k": "vim::GoToPreviousTab"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "g shift-t": "vim::GoToPreviousTab"
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "alt-h": "pane::GoBack"
    }
  },
  {
    "context": "Pane",
    "unbind": {
      "ctrl-alt--": "pane::GoBack"
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "alt-l": "pane::GoForward"
    }
  },
  {
    "context": "Pane",
    "unbind": {
      "ctrl-alt-_": "pane::GoForward"
    }
  }
]
